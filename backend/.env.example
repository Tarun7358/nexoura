# ===== Backend Configuration =====

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/nexoura?retryWrites=true&w=majority
DB_NAME=nexoura

# Server
PORT=5000
NODE_ENV=development
BASE_URL=http://localhost:5000

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# ===== Firebase (Backend) =====

# Option A (recommended for Render): full JSON in one env var
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"..."}

# Option B: split service account fields
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional Realtime DB URL (only if used)
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# ===== Email Configuration (for notifications) =====

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM=noreply@nexoura.com

# ===== Payment Gateway =====

# Razorpay (for deposits/payments)
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=rzp_test_xxxxx

# Optional: PhonePe
PHONOPE_MERCHANT_ID=MERCHANTID
PHONOPE_API_KEY=api_key_xxxx

# ===== Admin Configuration =====

ADMIN_EMAIL=admin@nexoura.com
ADMIN_PASSWORD=secure-admin-password

# ===== Logging =====

LOG_LEVEL=info
LOG_FORMAT=combined

# ===== CORS =====

CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ===== Session =====

SESSION_SECRET=your-session-secret-key

# ===== API Keys (third-party services) =====

# If using external APIs for authenticity verification, game stats, etc.
# EXTERNAL_API_KEY=xxxx
